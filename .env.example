# Brian English Studio V1.0 official config
# Copy to .env.local for local development.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ADMIN_EMAILS=your-admin-email@example.com

# Optional legacy/default AI values. AI provider keys are usually entered in Settings inside the app.
VITE_GEMINI_API_KEY=
# Server-side AI integration for Vercel Functions.
# Do NOT prefix this with VITE_; it must stay server-side.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini

# Brian Resource Library / Google Drive OAuth (server-side only)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=https://your-domain.com/api/google-drive-callback
GOOGLE_OAUTH_STATE_SECRET=replace-with-a-long-random-secret
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=https://your-domain.com
