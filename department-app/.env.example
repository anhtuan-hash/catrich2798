# Use the same Supabase project as Brian English Studio.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# UUID of the row in public.departments for the English department.
VITE_DEPARTMENT_ID=00000000-0000-0000-0000-000000000001

# Local development only. Never commit a real access token.
# Normally the app reads Brian's standard sb-*-auth-token session from localStorage.
VITE_DEPARTMENT_DEV_ACCESS_TOKEN=
