{
  "name": "brian-english-studio",
  "private": true,
  "version": "11.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "version:sync": "node scripts/sync-version-v11.0.mjs",
    "build": "npm run version:sync && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node scripts/smoke-test.mjs",
    "test:department": "node scripts/department-runtime-test.mjs",
    "audit:performance": "node scripts/performance-audit.mjs",
    "audit:budget": "node scripts/performance-budget-v11.0.0.mjs",
    "test:e2e:contracts": "node scripts/e2e-contract-test-v10.99.mjs",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium-desktop",
    "release:guard": "node scripts/release-guard-v11.0.0.mjs",
    "test:v11.0": "node scripts/check-v11.0.0.mjs",
    "release:guard:v11.0": "node scripts/release-guard-v11.0.0.mjs",
    "verify:v11.0": "npm run test:v11.0 && npm run build && npm run audit:budget && npm test && npm run test:department && npm run test:e2e:contracts && npm run release:guard:v11.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "read-excel-file": "^9.3.1",
    "vite": "^8.1.3"
  },
  "description": "Brian English Studio V11.0.0 - Connected Teaching Suite with Lesson Pack, live teaching sequences and cross-app content workflow.",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@10.8.0",
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
